# ============================================================
# HITL Gateway — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# --- Azure Functions ---
AzureWebJobsStorage=UseDevelopmentStorage=true
FUNCTIONS_WORKER_RUNTIME=python

# --- Webhook URLs (leave empty for mock/local dev) ---
TEAMS_WEBHOOK_URL=
SLACK_WEBHOOK_URL=
ESCALATION_WEBHOOK_URL=

# --- Telegram Notifications ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ADMIN_CHAT_ID=

# --- Dashboard ---
DASHBOARD_URL=https://your-dashboard.azurewebsites.net

# --- Email Reports (Resend) ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=HITL Gateway <reports@hitl-gateway.io>
REPORT_EMAIL=

# --- Emergency Phone Call (Twilio) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# --- Logging ---
LOG_LEVEL=INFO

# --- HITL Gateway Core ---
HITL_ENVIRONMENT=development
HITL_DEBUG=true
GATEWAY_URL=http://localhost:7072/api
AGENT_PORT=7071

# --- Security (required in production) ---
HITL_API_KEYS=
HITL_WEBHOOK_SECRET=
HITL_ENFORCE_HTTPS=false
HITL_ALLOWED_CALLBACK_DOMAINS=localhost,*.azurewebsites.net,*.azure-api.net

# --- Rate Limiting ---
HITL_RATE_LIMIT_WINDOW=60
HITL_RATE_LIMIT_MAX=30

# --- SLA Timeouts (seconds) ---
HITL_SLA_CRITICAL=300
HITL_SLA_HIGH=900
HITL_SLA_NORMAL=3600
HITL_SLA_LOW=86400

# --- Observability ---
APPLICATIONINSIGHTS_CONNECTION_STRING=
HITL_ENABLE_METRICS=true

# --- Cosmos DB (Phase 2) ---
COSMOS_CONNECTION_STRING=
COSMOS_DATABASE=hitl_gateway

# --- Redis (Phase 2) ---
REDIS_URL=

# --- Supabase (if using MCP server) ---
SUPABASE_ACCESS_TOKEN=
